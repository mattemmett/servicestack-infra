aws_region                        = "us-east-1"
project_name                      = "servicestack"
environment                       = "prod"
vpc_cidr                          = "10.30.0.0/16"
public_subnet_cidr                = "10.30.1.0/24"
public_availability_zone          = "us-east-1b"
private_subnet_a_cidr             = "10.30.11.0/24"
private_subnet_b_cidr             = "10.30.12.0/24"
private_subnet_a_availability_zone = "us-east-1a"
private_subnet_b_availability_zone = "us-east-1b"
ssh_cidr_blocks                   = ["203.0.113.10/32"]
host_instance_type                = "t3.small"
host_root_volume_size             = 30
host_associate_public_ip_address  = true
db_identifier                     = "servicestack-prod"
db_name                           = "servicestack"
db_instance_class                 = "db.t4g.micro"
db_allocated_storage              = 20
db_max_allocated_storage          = 100
